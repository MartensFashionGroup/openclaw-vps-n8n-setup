# .env.example for n8n Docker Compose
# Copy this file to .env and fill in your values.

# --- n8n Configuration ---
# For custom domain setup with a reverse proxy (e.g., Nginx, Caddy)
# If you're not using a custom domain and reverse proxy, you can comment these out or set to localhost
SUBDOMAIN=n8n
DOMAIN_NAME=example.com

# n8n Basic Authentication Credentials
N8N_USERNAME=admin
N8N_PASSWORD=your_n8n_secure_password_here # CHANGE THIS TO A STRONG PASSWORD!

# --- PostgreSQL Database Configuration ---
POSTGRES_DB=n8n_database
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=your_postgres_secure_password_here # CHANGE THIS TO A STRONG PASSWORD!

# --- SMTP Configuration (Optional, for sending emails from n8n) ---
# N8N_SMTP_HOST=smtp.example.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=your_smtp_user
# N8N_SMTP_PASS=your_smtp_password
# N8N_SMTP_SENDER=n8n@example.com